<section class="page" id="form_login">
    <h2>Login</h2>
    <form onsubmit="Auth.login(event)">
        <fieldset>
            <label for="login_email">Your Email</label>
            <input id="login_email" placeholder="joao.antonio@...com" type="email" autocomplete="username" required>
            <label for="login_password">Your Password</label>
            <input id="login_password" type="password" autocomplete="current-password" required>
        </fieldset>
        <button type="submit">Login</button>
        <fieldset>
            <div id="g_id_onload"
                 data-client_id="985634069069-fgegqtlbjbk2eui04lce5kkdoaml3egt.apps.googleusercontent.com"
                 data-context="signin"
                 data-ux_mode="popup"
                 data-callback="loginFromGoogle"
                 data-auto_prompt="false">
            </div>

            <div class="g_id_signin"
                 data-type="standard"
                 data-shape="pill"
                 data-theme="filled_black"
                 data-text="signin"
                 data-size="large"
                 data-logo_alignment="left">
            </div>
        </fieldset>
    </form>
</section>
